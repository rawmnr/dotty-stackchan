__pycache__/
*.py[cod]
.venv/
.venv-*/
venv/
*.log
.DS_Store

# Claude Code session artifacts (lock files, local settings)
.claude/

# learn-tutor progress + transcripts (per-project tutor state)
.learn-tutor/

# Secrets / credentials — never commit
.env
.env.*
!.env.example
!.env.proxmox.example
*.pem
*.key
*_rsa
*_rsa.pub
*_ed25519
*_ed25519.pub
id_*
secrets.*
credentials.*
*.p12
*.pfx

# SBOM artifacts — regenerated by scripts/generate-sbom.sh
sbom.json
sbom-server.json

# pytest-cov artifacts (regenerated each run)
.coverage
.coverage.*
htmlcov/
.pytest_cache/

# Frontend build deps for the dashboard's vendored Tailwind bundle.
# package.json + tailwind.config.js are committed; build artifacts and
# the npm install state are not. Re-run `npm install && npm run build:css`
# to regenerate bridge/static/tailwind.min.css.
node_modules/
package-lock.json

# `make setup` artifacts — rendered from *.template files. Sources live in
# git (.config.yaml.template, docker-compose.yml.template,
# zeroclaw-bridge.service.template); rendered copies are per-deployment.
/.config.yaml
/data/.config.yaml
/docker-compose.yml
/zeroclaw-bridge.service
/.wizard.env

# Downloaded ASR/TTS model weights (fetched by `make fetch-models`). Big
# binaries, easy to regenerate; not part of the repo.
/models/
