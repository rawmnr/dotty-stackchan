{
  "name": "dotty-pi-ext",
  "version": "0.1.0",
  "description": "Pi extension exposing Dotty's voice tools (memory_lookup, remember, think_hard, take_photo, play_song). Ports bridge.py's _voice_tool_* handlers per #36.",
  "type": "module",
  "private": true,
  "pi": {
    "extensions": ["./src/index.ts"]
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "typebox": "^1.1.38"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0"
  },
  "scripts": {
    "test": "npm run test:memory && npm run test:recall && npm run test:remember && npm run test:rememberperson && npm run test:turnlog && npm run test:think && npm run test:play",
    "test:memory": "node --experimental-strip-types tests/memory_lookup.test.ts",
    "test:recall": "node --experimental-strip-types tests/recall_person.test.ts",
    "test:remember": "node --experimental-strip-types tests/remember.test.ts",
    "test:rememberperson": "node --experimental-strip-types tests/remember_person.test.ts",
    "test:turnlog": "node --experimental-strip-types tests/turn_log.test.ts",
    "test:think": "node --experimental-strip-types tests/think_hard.test.ts",
    "test:play": "node --experimental-strip-types tests/play_song.test.ts"
  }
}
