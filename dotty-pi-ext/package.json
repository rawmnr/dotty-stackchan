{
  "name": "dotty-pi-ext",
  "version": "0.1.0",
  "description": "Pi extension exposing Dotty's voice tools, including memory, music, photo, person recall, and Rawmlab Home Assistant bridge helpers.",
  "type": "module",
  "private": true,
  "pi": {
    "extensions": ["./src/index.ts"]
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "typebox": "^1.1.38"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0"
  },
  "scripts": {
    "test": "npm run test:memory && npm run test:memgate && npm run test:recall && npm run test:remember && npm run test:rememberperson && npm run test:turnlog && npm run test:think && npm run test:play && npm run test:ha && npm run test:adminauth && npm run test:guardrails",
    "test:memory": "node --experimental-strip-types tests/memory_lookup.test.ts",
    "test:memgate": "node --experimental-strip-types tests/memory_gate.test.ts",
    "test:recall": "node --experimental-strip-types tests/recall_person.test.ts",
    "test:remember": "node --experimental-strip-types tests/remember.test.ts",
    "test:rememberperson": "node --experimental-strip-types tests/remember_person.test.ts",
    "test:turnlog": "node --experimental-strip-types tests/turn_log.test.ts",
    "test:think": "node --experimental-strip-types tests/think_hard.test.ts",
    "test:play": "node --experimental-strip-types tests/play_song.test.ts",
    "test:ha": "node --experimental-strip-types tests/home_assistant.test.ts",
    "test:adminauth": "node --experimental-strip-types tests/admin_auth.test.ts",
    "test:guardrails": "node --experimental-strip-types tests/guardrails.test.ts"
  }
}
