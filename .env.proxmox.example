# Copy to .env.proxmox before running:
#   cp .env.proxmox.example .env.proxmox

TZ=Europe/Paris

# LAN IP of the VM or LXC host seen by StackChan on WiFi.
DOTTY_HOST_LAN_IP=192.168.1.50

# Shared admin token for xiaozhi admin routes and all callers.
DOTTY_ADMIN_TOKEN=change-me

# Cloud keys are optional unless your chosen config/provider needs them.
OPENROUTER_API_KEY=
VISION_API_KEY=
VLM_API_KEY=

# Home Assistant bridge (dotty-pi-ext).
HOME_ASSISTANT_ENABLED=false
HOME_ASSISTANT_BASE_URL=http://homeassistant.home.arpa:8123
HOME_ASSISTANT_TOKEN=
HOME_ASSISTANT_TIMEOUT_SECONDS=10

# Optional local narrative backend for dotty-behaviour.
NARRATIVE_LLM_URL=http://127.0.0.1:8080/v1
NARRATIVE_MODEL=qwen3.6:27b-think
NARRATIVE_TIMEOUT_SEC=90

# Runtime paths. Relative paths resolve from the repo root where
# compose.proxmox.yml lives.
DOTTY_CONFIG_PATH=./data/.config.yaml
DOTTY_SENSEVOICE_MODEL_DIR=./models/SenseVoiceSmall
DOTTY_PIPER_MODEL_DIR=./models/piper
DOTTY_WHISPER_MODEL_DIR=./models/whisper-small.en-ct2
DOTTY_TMP_DIR=./runtime/xiaozhi/tmp
DOTTY_BIN_DIR=./runtime/xiaozhi/bin
DOTTY_SHARED_STATE_DIR=./runtime/shared-state
DOTTY_PI_STATE_DIR=./runtime/dotty-pi
DOTTY_BEHAVIOUR_LOG_DIR=./runtime/dotty-behaviour/logs
DOTTY_BEHAVIOUR_SECRETS_DIR=./runtime/dotty-behaviour/secrets
DOTTY_BRIDGE_LOG_DIR=./runtime/dotty-bridge/logs
DOTTY_BRIDGE_SECRETS_DIR=./runtime/dotty-bridge/secrets
